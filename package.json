{
  "name": "@flowforge-n8n/cli",
  "version": "0.2.0",
  "type": "module",
  "description": "The AI engineering toolkit for generating, validating, testing, documenting, and debugging n8n workflows.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "flowforge": "./dist/cli.js"
  },
  "files": [
    "dist",
    "schemas",
    "scripts",
    "templates",
    ".claude-plugin",
    "commands",
    "skills",
    "agents",
    "hooks"
  ],
  "scripts": {
    "flowforge": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "templates:build": "tsx scripts/build-templates.ts",
    "update:catalog": "tsx scripts/update-catalog.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "n8n",
    "workflow",
    "claude",
    "cli",
    "linter",
    "sanitizer",
    "secrets",
    "generator"
  ],
  "author": "FlowForge contributors",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "eslint": "^9.1.1",
    "prettier": "^3.2.5",
    "tsup": "^8.0.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.62.1",
    "vitest": "^1.5.0"
  }
}
