{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flowforge-n8n.local/schemas/flowforge.eval.schema.json",
  "title": "FlowForge eval file",
  "type": "object",
  "required": ["cases"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "input", "expectation"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "input": true,
          "expectation": {
            "type": "object",
            "required": ["type", "value"],
            "additionalProperties": false,
            "properties": {
              "type": { "enum": ["exact", "contains", "jsonSchema", "toolCalls"] },
              "value": true
            }
          }
        }
      }
    },
    "recordings": { "type": "object", "additionalProperties": true }
  }
}
