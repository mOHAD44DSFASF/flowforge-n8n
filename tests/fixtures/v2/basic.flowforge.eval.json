{
  "name": "basic eval",
  "cases": [
    {
      "id": "exact-case",
      "input": "hello",
      "expectation": { "type": "exact", "value": "hello world" }
    },
    {
      "id": "schema-case",
      "input": { "prompt": "classify" },
