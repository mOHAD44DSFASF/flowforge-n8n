{
  "nodes": [
    {
      "id": "t1",
      "name": "Trigger Deploy",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        100,
        200
      ],
      "parameters": {
        "path": "deploy-hook",
        "httpMethod": "POST"
      }
    },
    {
      "id": "n2",
      "name": "Slack Approval Block",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [
        300,
        200
      ],
      "parameters": {
        "url": "https://slack.com/api/chat.postMessage",
        "method": "POST"
      }
    },
    {
      "id": "n3",
      "name": "Deploy Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        500,
        200
      ],
      "parameters": {
        "responseCode": 200
      }
    }
  ],
  "connections": {
    "Trigger Deploy": {
      "main": [
        [
          {
            "node": "Slack Approval Block",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Slack Approval Block": {
      "main": [
        [
          {
            "node": "Deploy Respond OK",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}